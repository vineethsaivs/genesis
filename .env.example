# === LLM Provider Keys ===
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...              # Required for browser-use

# === Search ===
SERPER_API_KEY=                     # POST https://google.serper.dev/search

# === LLM Defaults ===
DEFAULT_LLM_PROVIDER=anthropic     # anthropic | openai
DEFAULT_MODEL=claude-sonnet-4-20250514

# === Observability ===
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=genesis

# === Paths ===
SKILLS_DIR=generated_skills
DB_PATH=data/genesis.db
SKILL_TREE_PATH=data/skill_tree.json

# === Server ===
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
